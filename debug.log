  %".5" = insertvalue {i8*, i64} undef, i8* getelementptr ([16 x i8], [16 x i8]* @".2", i32 0, i32 0), 0
  %".6" = insertvalue {i8*, i64} %".5", i64 16, 1
  ret {i8*, i64} %".6"
}

