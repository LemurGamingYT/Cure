fn main() -> int {
    a = 1
    b = 2

    print("Running operation tests")
    assert(a + b == 3, "a + b == 3 returned false")
    assert(a - b == -1, "a - b == -1 returned false")
    assert(a * b == 2, "a * b == 2 returned false")
    assert(a / b == 0, "a / b == 0 returned false")
    assert(a % b == 1, "a % b == 1 returned false")
    assert_not(a == b, "a == b returned true")
    assert(a != b, "a != b returned false")
    assert_not(a > b, "a > b returned true")
    assert(a < b, "a < b returned false")
    assert_not(a >= b, "a >= b returned true")
    assert(a <= b, "a <= b returned false")
    print("All operation tests passed")

    print("All tests passed")
    return 0
}
